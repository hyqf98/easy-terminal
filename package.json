{
  "name": "easy-terminal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo 'No linting configured yet. Consider adding ESLint.'",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=json --outputFile=test-reports/vitest-report.json && npx tsx scripts/generate-test-report.ts",
    "test:report:only": "npx tsx scripts/generate-test-report.ts"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "lucide-vue-next": "^0.576.0",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.4",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "2": "^3.0.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.7.0",
    "monaco-editor": "^0.55.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
